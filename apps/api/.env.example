# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Frontend (CORS) ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string with pgvector enabled.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&sslmode=require
DATABASE_URL=postgresql://postgres:placeholder@db.your-project.supabase.co:5432/postgres?schema=public&sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: `openssl rand -base64 64`
# Drop-in replacement point: change this secret (and the middleware logic in
# src/middleware/auth.ts) to support Recall-compatible auth tokens.
JWT_SECRET=change-me-to-a-long-random-secret

# ─── LLM — Groq (primary) ────────────────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=placeholder

# ─── LLM — Gemini (fallback + embeddings) ────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
# Used for: text-embedding-004 (768-dim), gemini-1.5-flash fallback
GEMINI_API_KEY=placeholder

# ─── Application logic ────────────────────────────────────────────────────────
# Minimum fit score (0-100) required to proceed with CV tailoring
FIT_SCORE_THRESHOLD=60

# Number of days without a status update before an APPLIED application
# is automatically marked as GHOSTED by the daily cron sweep.
GHOSTED_THRESHOLD_DAYS=21
