# ============================================================
# Pipeline — Environment Variables
# Copy this file to .env (API) and .env.local (web) and fill
# in real values. Never commit files with actual secrets.
# ============================================================

# --------------------------------------------------
# DATABASE (Supabase — pgvector is pre-installed)
# --------------------------------------------------
# Connection string from Supabase Dashboard > Project Settings > Database
# Use the "Transaction" pooler URL (port 6543) for serverless/edge,
# or the direct URL (port 5432) for Prisma migrations.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres"

# --------------------------------------------------
# AUTH
# --------------------------------------------------
# A long random secret for signing JWTs issued by the Express API.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_64_BYTE_HEX_SECRET"

# NextAuth secret — separate from the API JWT secret.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_NEXTAUTH_SECRET"

# The canonical URL of the Next.js frontend (used by NextAuth for callbacks).
NEXTAUTH_URL="http://localhost:3000"

# --------------------------------------------------
# API CONNECTIVITY
# --------------------------------------------------
# URL of the Express backend. In development: http://localhost:3001
# In production: your Render service URL (e.g. https://pipeline-api.onrender.com)
API_URL="http://localhost:3001"

# Exposed to Next.js browser bundles — must match API_URL in dev,
# or your production API URL when deployed.
NEXT_PUBLIC_API_URL="http://localhost:3001"

# --------------------------------------------------
# LLM PROVIDERS (Groq → Gemini fallback)
# --------------------------------------------------
# Groq API key — primary provider (Llama 3)
# Get at: https://console.groq.com/keys
GROQ_API_KEY="REPLACE_WITH_GROQ_KEY"

# Google Gemini API key — fallback provider (Gemini Flash)
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="REPLACE_WITH_GEMINI_KEY"

# --------------------------------------------------
# CV / FILE STORAGE (Supabase Storage)
# --------------------------------------------------
# Supabase project reference ID (found in project settings)
SUPABASE_PROJECT_REF="REPLACE_WITH_PROJECT_REF"

# Supabase service-role key (never expose to browser)
# Found in: Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_KEY="REPLACE_WITH_SERVICE_KEY"

# --------------------------------------------------
# FEATURE FLAGS
# --------------------------------------------------
# Ghosted sweep: applications with APPLIED status older than this many
# days with no update are flagged as GHOSTED. Default: 21.
GHOSTED_THRESHOLD_DAYS="21"

# Fit score threshold: job postings below this score (0-100) are
# discarded before the full LLM tailoring call. Default: 60.
FIT_SCORE_THRESHOLD="60"

# --------------------------------------------------
# EMAIL INTEGRATION (STUB — deferred to later phase)
# --------------------------------------------------
# Google OAuth client for Gmail read-only scanning.
# Leave blank for now — the feature is stubbed/disabled.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
